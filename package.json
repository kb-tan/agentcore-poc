{
  "name": "agentcore-langgraph-poc",
  "version": "1.0.0",
  "description": "AWS Bedrock AgentCore POC with LangGraph.js - demonstrates memory, tool use, traceability, and A/B testing",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "npx tsx src/server.ts",
    "client": "npx tsx src/client/index.ts",
    "client:trace": "npx tsx src/client/index.ts --trace",
    "client:ab": "npx tsx src/client/index.ts --ab"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@langchain/langgraph": "^0.2.0",
    "@langchain/core": "^0.3.0",
    "@langchain/aws": "^0.1.0",
    "express": "^4.21.0",
    "zod": "^3.23.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/sdk-trace-node": "^1.30.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "tsx": "^4.0.0"
  }
}
